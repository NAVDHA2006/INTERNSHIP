<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TASKFLOW — Task Management</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
/* ─── RESET & TOKENS ───────────────────────────────── */
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#0d0d0d;--paper:#f5f2ec;--paper2:#ede9df;--paper3:#e4e0d4;
  --accent:#e63946;--accent2:#457b9d;--accent3:#2a9d8f;
  --warn:#f4a261;--muted:#8a8578;--border:#c8c3b5;
  --card:#faf8f4;--shadow:2px 3px 0 #c8c3b5;
  --font-head:'Syne',sans-serif;--font-mono:'Space Mono',monospace;
  --rad:3px;--rad-lg:6px;
}
html,body{height:100%;background:var(--paper);color:var(--ink);font-family:var(--font-mono);font-size:13px;line-height:1.5}

/* ─── SCROLLBAR ─────────────────────────────────────── */
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:var(--paper2)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:var(--muted)}

/* ─── AUTH SCREEN ───────────────────────────────────── */
#authScreen{
  display:flex;align-items:center;justify-content:center;
  min-height:100vh;background:var(--ink);
  background-image:repeating-linear-gradient(0deg,transparent,transparent 39px,rgba(255,255,255,.04) 39px,rgba(255,255,255,.04) 40px),
                   repeating-linear-gradient(90deg,transparent,transparent 39px,rgba(255,255,255,.04) 39px,rgba(255,255,255,.04) 40px);
}
.auth-card{
  background:var(--paper);border:2px solid var(--paper3);
  width:100%;max-width:400px;padding:0;
  box-shadow:6px 6px 0 rgba(255,255,255,.06);
}
.auth-header{
  background:var(--accent);padding:24px 28px;
  display:flex;flex-direction:column;gap:4px;
}
.auth-logo{font-family:var(--font-head);font-size:26px;font-weight:800;color:#fff;letter-spacing:-1px}
.auth-tagline{font-family:var(--font-mono);font-size:11px;color:rgba(255,255,255,.75);letter-spacing:.5px}
.auth-body{padding:28px}
.auth-tabs{display:flex;gap:0;margin-bottom:22px;border:1px solid var(--border)}
.auth-tab{flex:1;padding:8px;background:none;border:none;cursor:pointer;font-family:var(--font-mono);font-size:12px;color:var(--muted);letter-spacing:.5px;transition:all .15s}
.auth-tab.active{background:var(--ink);color:var(--paper);font-weight:700}
.field{margin-bottom:14px}
.field label{display:block;font-size:11px;letter-spacing:.8px;text-transform:uppercase;color:var(--muted);margin-bottom:5px}
.field input,.field select,.field textarea{
  width:100%;background:var(--paper2);border:1px solid var(--border);
  color:var(--ink);padding:9px 11px;font-family:var(--font-mono);font-size:12px;
  outline:none;transition:border .15s;border-radius:var(--rad)
}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--ink)}
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:6px;
  padding:9px 16px;border:1px solid var(--ink);background:var(--ink);color:var(--paper);
  font-family:var(--font-mono);font-size:12px;font-weight:700;letter-spacing:.4px;
  cursor:pointer;transition:all .15s;border-radius:var(--rad);white-space:nowrap
}
.btn:hover{background:transparent;color:var(--ink)}
.btn-outline{background:transparent;color:var(--ink)}
.btn-outline:hover{background:var(--ink);color:var(--paper)}
.btn-accent{background:var(--accent);border-color:var(--accent);color:#fff}
.btn-accent:hover{background:transparent;color:var(--accent)}
.btn-sm{padding:5px 10px;font-size:11px}
.btn-full{width:100%}
.btn-danger{background:var(--accent);border-color:var(--accent);color:#fff}
.btn-danger:hover{background:transparent;color:var(--accent)}
.btn-success{background:var(--accent3);border-color:var(--accent3);color:#fff}
.btn-success:hover{background:transparent;color:var(--accent3)}
.auth-hint{font-size:11px;color:var(--muted);margin-top:12px;padding:10px;background:var(--paper2);border-left:3px solid var(--accent)}

/* ─── MAIN APP ──────────────────────────────────────── */
#mainApp{display:none;flex-direction:column;min-height:100vh}

/* ─── HEADER ────────────────────────────────────────── */
.app-header{
  background:var(--ink);color:var(--paper);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 20px;height:52px;position:sticky;top:0;z-index:200;
  border-bottom:2px solid var(--accent)
}
.header-logo{font-family:var(--font-head);font-size:18px;font-weight:800;letter-spacing:-0.5px;color:var(--paper)}
.header-logo span{color:var(--accent)}
.header-right{display:flex;align-items:center;gap:10px}
.user-pill{display:flex;align-items:center;gap:7px;font-size:11px;color:rgba(255,255,255,.65)}
.user-avatar{width:28px;height:28px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;color:#fff;flex-shrink:0}
.ws-indicator{display:flex;align-items:center;gap:5px;font-size:10px;color:rgba(255,255,255,.5);letter-spacing:.3px}
.ws-dot{width:6px;height:6px;border-radius:50%;background:var(--accent3);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}

/* ─── LAYOUT ────────────────────────────────────────── */
.app-body{display:flex;flex:1;overflow:hidden;height:calc(100vh - 52px)}
.sidebar{
  width:220px;background:var(--paper2);border-right:1px solid var(--border);
  display:flex;flex-direction:column;padding:16px 0;flex-shrink:0;overflow-y:auto
}
.sidebar-section{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--muted);padding:0 16px;margin:14px 0 6px}
.sidebar-item{
  display:flex;align-items:center;gap:9px;padding:8px 16px;
  cursor:pointer;color:var(--muted);font-size:12px;transition:all .15s;
  border:none;background:none;text-align:left;width:100%;
  border-left:3px solid transparent
}
.sidebar-item:hover{background:var(--paper3);color:var(--ink)}
.sidebar-item.active{background:var(--paper3);color:var(--ink);border-left-color:var(--accent);font-weight:700}
.sidebar-count{margin-left:auto;font-size:10px;background:var(--border);color:var(--ink);padding:1px 6px;border-radius:9px;font-weight:700}
.sidebar-count.hot{background:var(--accent);color:#fff}
.divider{height:1px;background:var(--border);margin:8px 16px}
.content{flex:1;overflow-y:auto;padding:22px}

/* ─── KANBAN BOARD ──────────────────────────────────── */
.board{display:flex;gap:14px;min-width:max-content;padding-bottom:12px}
.board-col{
  width:280px;flex-shrink:0;display:flex;flex-direction:column;gap:10px
}
.col-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 12px;background:var(--paper2);border:1px solid var(--border);
  border-top:3px solid currentColor
}
.col-header.todo{color:#457b9d}
.col-header.inprogress{color:#f4a261}
.col-header.review{color:#a8dadc}
.col-header.done{color:#2a9d8f}
.col-title{font-family:var(--font-head);font-size:13px;font-weight:700;letter-spacing:.3px}
.col-count{font-size:11px;opacity:.7}
.task-card{
  background:var(--card);border:1px solid var(--border);
  padding:13px;cursor:pointer;transition:all .18s;
  box-shadow:var(--shadow);position:relative;
  animation:slideIn .25s ease
}
@keyframes slideIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.task-card:hover{box-shadow:4px 5px 0 var(--border);transform:translate(-1px,-1px)}
.task-card.dragging{opacity:.4}
.task-card.drag-over{border-color:var(--accent);border-style:dashed}
.task-title{font-family:var(--font-head);font-size:13px;font-weight:600;margin-bottom:6px;line-height:1.3}
.task-desc{font-size:11px;color:var(--muted);margin-bottom:9px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.task-meta{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.priority-tag{font-size:10px;font-weight:700;letter-spacing:.5px;padding:2px 7px;border-radius:var(--rad)}
.p-critical{background:#e63946;color:#fff}
.p-high{background:#f4a261;color:#fff}
.p-medium{background:#457b9d;color:#fff}
.p-low{background:#2a9d8f;color:#fff}
.task-due{font-size:10px;color:var(--muted);margin-left:auto;display:flex;align-items:center;gap:3px}
.task-due.overdue{color:var(--accent);font-weight:700}
.task-assignee{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;flex-shrink:0}
.task-actions{position:absolute;top:8px;right:8px;display:none;gap:4px}
.task-card:hover .task-actions{display:flex}
.task-tag{font-size:10px;background:var(--paper2);border:1px solid var(--border);padding:1px 6px;border-radius:var(--rad);color:var(--muted)}
.add-task-btn{
  padding:10px 12px;border:1px dashed var(--border);background:none;
  width:100%;text-align:left;font-family:var(--font-mono);font-size:11px;
  color:var(--muted);cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:6px
}
.add-task-btn:hover{background:var(--paper2);border-style:solid;color:var(--ink)}

/* ─── LIST VIEW ─────────────────────────────────────── */
.list-view{display:flex;flex-direction:column;gap:0}
.list-header{
  display:grid;grid-template-columns:1fr 90px 100px 90px 80px;
  gap:8px;padding:8px 14px;background:var(--paper2);border:1px solid var(--border);
  font-size:10px;letter-spacing:.8px;text-transform:uppercase;color:var(--muted);font-weight:700
}
.list-row{
  display:grid;grid-template-columns:1fr 90px 100px 90px 80px;
  gap:8px;padding:10px 14px;border:1px solid var(--border);border-top:none;
  background:var(--card);transition:background .12s;cursor:pointer;align-items:center
}
.list-row:hover{background:var(--paper2)}
.list-row.done-row .task-title-list{text-decoration:line-through;opacity:.5}

/* ─── DASHBOARD STATS ──────────────────────────────── */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-bottom:20px}
.stat-card{
  background:var(--card);border:1px solid var(--border);padding:16px;
  box-shadow:var(--shadow);position:relative;overflow:hidden
}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.stat-card.c-red::before{background:var(--accent)}
.stat-card.c-blue::before{background:var(--accent2)}
.stat-card.c-green::before{background:var(--accent3)}
.stat-card.c-warn::before{background:var(--warn)}
.stat-num{font-family:var(--font-head);font-size:32px;font-weight:800;line-height:1}
.stat-lbl{font-size:10px;letter-spacing:.7px;text-transform:uppercase;color:var(--muted);margin-top:4px}
.stat-sub{font-size:11px;color:var(--muted);margin-top:6px}

/* ─── MODAL ────────────────────────────────────────── */
.modal-overlay{
  position:fixed;inset:0;background:rgba(13,13,13,.7);z-index:300;
  display:flex;align-items:center;justify-content:center;padding:16px
}
.modal{
  background:var(--paper);border:2px solid var(--ink);width:100%;max-width:520px;
  max-height:90vh;overflow-y:auto;box-shadow:8px 8px 0 rgba(13,13,13,.3)
}
.modal-header{
  background:var(--ink);color:var(--paper);padding:14px 20px;
  display:flex;align-items:center;justify-content:space-between
}
.modal-title{font-family:var(--font-head);font-size:15px;font-weight:700}
.close-btn{background:none;border:none;color:rgba(255,255,255,.6);cursor:pointer;font-size:20px;line-height:1;padding:0}
.close-btn:hover{color:#fff}
.modal-body{padding:22px}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.modal-footer{padding:14px 20px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end}

/* ─── TOAST ────────────────────────────────────────── */
.toast-wrap{position:fixed;bottom:20px;right:20px;display:flex;flex-direction:column;gap:8px;z-index:500}
.toast{
  background:var(--ink);color:var(--paper);padding:11px 16px;
  font-family:var(--font-mono);font-size:12px;border-left:4px solid var(--accent);
  animation:toastIn .3s ease;max-width:320px;box-shadow:4px 4px 0 rgba(0,0,0,.2)
}
.toast.success{border-left-color:var(--accent3)}
.toast.warn{border-left-color:var(--warn)}
@keyframes toastIn{from{transform:translateX(120px);opacity:0}to{transform:translateX(0);opacity:1}}
@keyframes toastOut{from{opacity:1}to{opacity:0;transform:translateX(120px)}}
.toast.out{animation:toastOut .3s ease forwards}

/* ─── REALTIME FEED ─────────────────────────────────── */
.feed{
  position:fixed;bottom:20px;left:20px;width:260px;
  background:var(--ink);border:1px solid #222;z-index:100;
  max-height:200px;overflow:hidden
}
.feed-header{
  padding:7px 12px;border-bottom:1px solid #222;font-size:10px;
  letter-spacing:.6px;text-transform:uppercase;color:rgba(255,255,255,.4);
  display:flex;align-items:center;gap:6px
}
.feed-items{padding:8px 0;max-height:155px;overflow-y:auto}
.feed-item{
  padding:5px 12px;font-size:10px;color:rgba(255,255,255,.55);
  border-bottom:1px solid rgba(255,255,255,.04);display:flex;align-items:flex-start;gap:6px;
  animation:feedIn .3s ease
}
@keyframes feedIn{from{background:rgba(230,57,70,.15)}to{background:transparent}}
.feed-time{color:rgba(255,255,255,.25);flex-shrink:0}

/* ─── TOOLBAR ───────────────────────────────────────── */
.toolbar{display:flex;align-items:center;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.toolbar-title{font-family:var(--font-head);font-size:18px;font-weight:800;flex:1;letter-spacing:-.3px}
.view-toggle{display:flex;border:1px solid var(--border)}
.view-btn{padding:6px 11px;background:none;border:none;cursor:pointer;font-size:12px;color:var(--muted);transition:all .15s;font-family:var(--font-mono)}
.view-btn.active{background:var(--ink);color:var(--paper)}
.search-input{background:var(--paper2);border:1px solid var(--border);padding:7px 12px;font-family:var(--font-mono);font-size:12px;color:var(--ink);outline:none;width:180px}
.search-input:focus{border-color:var(--ink)}
.filter-select{background:var(--paper2);border:1px solid var(--border);padding:7px 10px;font-family:var(--font-mono);font-size:11px;color:var(--ink);outline:none;cursor:pointer}

/* ─── TAGS / MISC ───────────────────────────────────── */
.badge{display:inline-flex;align-items:center;padding:2px 8px;font-size:10px;font-weight:700;letter-spacing:.4px;border-radius:var(--rad)}
.progress-bar{height:3px;background:var(--paper3);margin-top:6px;border-radius:2px;overflow:hidden}
.progress-fill{height:100%;background:var(--accent3);transition:width .4s}
.empty-state{text-align:center;padding:40px 20px;color:var(--muted)}
.empty-icon{font-size:36px;margin-bottom:10px}
.profile-section{padding:16px;border-top:1px solid var(--border);margin-top:auto}
.profile-row{display:flex;align-items:center;gap:8px}
.profile-name{font-size:12px;font-weight:700}
.profile-role{font-size:10px;color:var(--muted);letter-spacing:.3px}

/* ─── RESPONSIVE ────────────────────────────────────── */
@media(max-width:768px){
  .sidebar{display:none}
  .board{flex-direction:column;min-width:unset}
  .board-col{width:100%}
  .list-header,.list-row{grid-template-columns:1fr 70px 80px}
  .hide-mob{display:none}
  .content{padding:14px}
  .feed{display:none}
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .grid-2{grid-template-columns:1fr}
}
@media(max-width:480px){
  .app-header{padding:0 12px}
  .header-logo{font-size:15px}
  .stats-grid{grid-template-columns:1fr 1fr}
  .toolbar{gap:6px}
  .search-input{width:130px}
}

/* ─── DRAG HIGHLIGHT ────────────────────────────────── */
.col-drop-zone{min-height:50px;transition:background .15s}
.col-drop-zone.drag-active{background:rgba(69,123,157,.1);border:1px dashed var(--accent2)}
</style>
</head>
<body>

<!-- ══ AUTH SCREEN ══════════════════════════════════ -->
<div id="authScreen">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo">TASK<span style="opacity:.6">FLOW</span></div>
      <div class="auth-tagline">// full-stack task management</div>
    </div>
    <div class="auth-body">
      <div class="auth-tabs">
        <button class="auth-tab active" onclick="authTab('login')" id="tabLogin">SIGN IN</button>
        <button class="auth-tab" onclick="authTab('register')" id="tabRegister">REGISTER</button>
      </div>
      <div id="loginForm">
        <div class="field"><label>Email</label><input id="loginEmail" type="email" value="alice@taskflow.io"></div>
        <div class="field"><label>Password</label><input id="loginPass" type="password" value="password"></div>
        <button class="btn btn-full btn-accent" onclick="doLogin()" style="margin-top:4px">SIGN IN →</button>
      </div>
      <div id="registerForm" style="display:none">
        <div class="field"><label>Full Name</label><input id="regName" placeholder="Jane Smith"></div>
        <div class="field"><label>Email</label><input id="regEmail" type="email" placeholder="jane@example.com"></div>
        <div class="field"><label>Password</label><input id="regPass" type="password" placeholder="Min. 6 chars"></div>
        <div class="field"><label>Role</label>
          <select id="regRole"><option value="Member">Member</option><option value="Admin">Admin</option></select>
        </div>
        <button class="btn btn-full btn-accent" onclick="doRegister()" style="margin-top:4px">CREATE ACCOUNT →</button>
      </div>
      <div class="auth-hint">
        <strong>Demo accounts:</strong><br>
        alice@taskflow.io / password (Admin)<br>
        bob@taskflow.io / password (Member)
      </div>
    </div>
  </div>
</div>

<!-- ══ MAIN APP ══════════════════════════════════════ -->
<div id="mainApp" style="display:none;flex-direction:column;min-height:100vh">

  <header class="app-header">
    <div class="header-logo">TASK<span style="color:var(--accent)">FLOW</span></div>
    <div class="header-right">
      <div class="ws-indicator">
        <div class="ws-dot"></div>
        <span class="hide-mob">LIVE</span>
      </div>
      <div class="user-pill">
        <div class="user-avatar" id="headerAvatar">?</div>
        <span class="hide-mob" id="headerName">User</span>
        <span class="hide-mob" id="headerRole" style="font-size:10px;opacity:.5"></span>
      </div>
      <button class="btn btn-sm btn-outline" style="border-color:rgba(255,255,255,.2);color:rgba(255,255,255,.7);background:none" onclick="doLogout()">LOGOUT</button>
    </div>
  </header>

  <div class="app-body">

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-section">Views</div>
      <button class="sidebar-item active" onclick="showView('board')" id="nav-board">
        ⬛ KANBAN BOARD <span class="sidebar-count" id="cnt-board">0</span>
      </button>
      <button class="sidebar-item" onclick="showView('list')" id="nav-list">
        ☰ LIST VIEW
      </button>
      <button class="sidebar-item" onclick="showView('dashboard')" id="nav-dashboard">
        ◈ DASHBOARD
      </button>

      <div class="divider"></div>
      <div class="sidebar-section">Filters</div>
      <button class="sidebar-item" onclick="setFilter('my')" id="filt-my">
        ◎ MY TASKS <span class="sidebar-count hot" id="cnt-my">0</span>
      </button>
      <button class="sidebar-item" onclick="setFilter('overdue')" id="filt-overdue">
        ⚠ OVERDUE <span class="sidebar-count hot" id="cnt-overdue">0</span>
      </button>
      <button class="sidebar-item" onclick="setFilter('critical')" id="filt-critical">
        ■ CRITICAL <span class="sidebar-count" id="cnt-critical">0</span>
      </button>
      <button class="sidebar-item" onclick="setFilter('all')" id="filt-all">
        ○ ALL TASKS
      </button>

      <div class="divider"></div>
      <div class="sidebar-section">Team</div>
      <div id="teamList" style="padding:0 10px"></div>

      <div class="profile-section">
        <div class="profile-row">
          <div class="user-avatar" id="sidebarAvatar" style="width:32px;height:32px;font-size:13px">?</div>
          <div>
            <div class="profile-name" id="sidebarName">—</div>
            <div class="profile-role" id="sidebarRole">—</div>
          </div>
        </div>
      </div>
    </aside>

    <!-- CONTENT -->
    <main class="content" id="mainContent">
      <!-- Injected dynamically -->
    </main>
  </div>
</div>

<!-- ══ REAL-TIME FEED ════════════════════════════════ -->
<div class="feed" id="rtFeed">
  <div class="feed-header"><div class="ws-dot"></div> ACTIVITY STREAM</div>
  <div class="feed-items" id="feedItems"></div>
</div>

<!-- ══ TOAST CONTAINER ══════════════════════════════ -->
<div class="toast-wrap" id="toastWrap"></div>

<!-- ══ MODALS ════════════════════════════════════════ -->

<!-- Task Modal -->
<div class="modal-overlay" id="taskModal" style="display:none" onclick="if(event.target===this)closeModal('taskModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-title" id="taskModalTitle">NEW TASK</div>
      <button class="close-btn" onclick="closeModal('taskModal')">✕</button>
    </div>
    <div class="modal-body">
      <div class="field"><label>Title *</label><input id="tTitle" placeholder="What needs to be done?"></div>
      <div class="field"><label>Description</label><textarea id="tDesc" rows="3" placeholder="Add details, links, context..."></textarea></div>
      <div class="grid-2">
        <div class="field"><label>Priority</label>
          <select id="tPriority">
            <option value="critical">CRITICAL</option>
            <option value="high">HIGH</option>
            <option value="medium" selected>MEDIUM</option>
            <option value="low">LOW</option>
          </select>
        </div>
        <div class="field"><label>Status</label>
          <select id="tStatus">
            <option value="todo">TODO</option>
            <option value="inprogress">IN PROGRESS</option>
            <option value="review">IN REVIEW</option>
            <option value="done">DONE</option>
          </select>
        </div>
      </div>
      <div class="grid-2">
        <div class="field"><label>Assign To</label>
          <select id="tAssignee"></select>
        </div>
        <div class="field"><label>Due Date</label>
          <input id="tDue" type="date">
        </div>
      </div>
      <div class="field"><label>Tags (comma separated)</label>
        <input id="tTags" placeholder="design, backend, urgent">
      </div>
