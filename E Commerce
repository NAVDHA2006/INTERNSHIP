/* ===== LOGIN ===== */
function setRole(r) {
  S.role = r;
  document.getElementById('roleUserBtn').className = 'role-btn' + (r==='user' ? ' active' : '');
  document.getElementById('roleAdminBtn').className = 'role-btn' + (r==='admin' ? ' active' : '');
  document.getElementById('loginEmail').value = r==='admin' ? 'admin@nexus.com' : 'user@nexus.com';
  document.getElementById('loginPass').value = r==='admin' ? 'admin123' : 'password123';
}

function doLogin() {
  var em = document.getElementById('loginEmail').value.trim();
  var pw = document.getElementById('loginPass').value;
  var isAdmin = em==='admin@nexus.com' && pw==='admin123';
  var isUser  = (em==='user@nexus.com' && pw==='password123') || em==='bob@nexus.com' || em==='alice@nexus.com';
  if (!isAdmin && !isUser) { showToast('❌ Invalid credentials'); return; }
  S.currentUser = em;
  S.role = isAdmin ? 'admin' : 'user';
  document.getElementById('loginScreen').style.display = 'none';
  var ma = document.getElementById('mainApp');
  ma.style.display = 'flex';
  document.getElementById('userLabel').textContent = em.split('@')[0];
  document.getElementById('roleBadge').textContent = S.role==='admin' ? 'Admin' : 'User';
  document.getElementById('roleBadge').className = 'tag ' + (S.role==='admin' ? 'tag-pink' : 'tag-purple');
  document.getElementById('adminSidebar').style.display = S.role==='admin' ? 'block' : 'none';
  S.section = 'catalog'; S.catFilter = 'all';
  renderCatalog();
  updateCartBadge();
  showToast('✅ Welcome, ' + em.split('@')[0] + '!');
}

function doLogout() {
  S.currentUser = null; S.role = 'user'; S.cart = [];
  document.getElementById('loginScreen').style.display = 'flex';
  document.getElementById('mainApp').style.display = 'none';
  document.getElementById('adminSidebar').style.display = 'none';
  setRole('user');
}

/* ===== NAVIGATION ===== */
function showSection(s) {
  S.section = s;
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  var pg = document.getElementById('page-' + s);
  if (pg) pg.classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  var nb = document.getElementById('nav-' + s);
  if (nb) nb.classList.add('active');
  document.querySelectorAll('.sidebar-item').forEach(b => b.classList.remove('active'));
  var sb = document.getElementById('sid-' + s);
  if (sb) sb.classList.add('active');
  var renders = {catalog:renderCatalog, cart:renderCart, orders:renderMyOrders, dashboard:renderDashboard, adminProducts:renderAdminProducts, adminOrders:renderAllOrders, users:renderUsers};
  if (renders[s]) renders[s]();
}

function filterCat(c) {
  S.catFilter = c;
  document.querySelectorAll('[id^="cat-"]').forEach(b => b.classList.remove('active'));
  var el = document.getElementById('cat-' + c);
  if (el) el.classList.add('active');
  showSection('catalog');
}

/* ===== CATALOG ===== */
function getFilteredProducts() {
  var q = (document.getElementById('searchInput')||{value:''}).value.toLowerCase();
  var sort = (document.getElementById('sortSelect')||{value:'default'}).value;
  var list = S.products.filter(p => {
    return (S.catFilter==='all' || p.cat===S.catFilter) &&
           (!q || p.name.toLowerCase().includes(q) || p.cat.toLowerCase().includes(q) || p.desc.toLowerCase().includes(q));
  });
  if (sort==='price-asc') list.sort((a,b)=>a.price-b.price);
  else if (sort==='price-desc') list.sort((a,b)=>b.price-a.price);
  else if (sort==='name') list.sort((a,b)=>a.name.localeCompare(b.name));
  return list;
}

function renderCatalog() {
  var prods = getFilteredProducts();
  var grid = document.getElementById('productGrid');
  if (!grid) return;
  if (!prods.length) {
    grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">🔍</div><p>No products found</p></div>';
    return;
  }
  grid.innerHTML = prods.map(p => {
    var inCart = S.cart.find(c => c.id===p.id);
    var stockHtml = p.stock>20 ? '<span class="tag tag-green">In Stock</span>' :
                    p.stock>0  ? '<span class="tag tag-orange">Low: '+p.stock+' left</span>' :
                                 '<span class="tag tag-red">Out of Stock</span>';
    var btnHtml = p.stock>0
      ? '<button class="btn btn-primary btn-sm" onclick="addToCart('+p.id+')">'+(inCart?'<i class="ti ti-check"></i> Added':'<i class="ti ti-plus"></i> Add')+'</button>'
      : '<button class="btn btn-outline btn-sm" disabled style="opacity:.5;cursor:not-allowed">Unavailable</button>';
    return '<div class="product-card"><div class="product-img">'+p.emoji+'</div><div class="product-info"><div class="product-cat">'+p.cat+'</div><div class="product-name">'+p.name+'</div><div class="product-stock">'+stockHtml+'</div><div style="display:flex;align-items:center;justify-content:space-between"><span style="color:var(--accent);font-weight:700;font-size:16px">$'+p.price.toFixed(2)+'</span>'+btnHtml+'</div></div></div>';
  }).join('');
}

/* ===== CART ===== */
function addToCart(id) {
  var p = S.products.find(x=>x.id===id);
  if (!p||p.stock===0) return;
  var ci = S.cart.find(c=>c.id===id);
  if (ci) ci.qty = Math.min(ci.qty+1, p.stock);
  else S.cart.push({id:p.id, name:p.name, price:p.price, emoji:p.emoji, qty:1});
  updateCartBadge(); renderCatalog();
  showToast('🛒 '+p.name+' added to cart');
}

function updateCartBadge() {
  document.getElementById('cartBadge').textContent = S.cart.reduce((a,c)=>a+c.qty, 0);
}

function renderCart() {
  var el = document.getElementById('cartItems');
  var sum = document.getElementById('orderSummary');
  if (!el) return;
  if (!S.cart.length) {
    el.innerHTML = '<div class="empty-state"><div class="empty-icon">🛒</div><p>Your cart is empty</p><br><button class="btn btn-primary" onclick="showSection(\'catalog\')">Start Shopping</button></div>';
    sum.innerHTML = '<div style="font-weight:600;margin-bottom:10px">Order Summary</div><div style="color:var(--muted);font-size:13px">No items yet</div>';
    return;
  }
  var subtotal = S.cart.reduce((a,c)=>a+c.price*c.qty, 0);
  var shipping = subtotal>=100 ? 0 : 9.99;
  var tax = subtotal * 0.08;
  var total = subtotal + shipping + tax;
  el.innerHTML = S.cart.map(c =>
    '<div class="cart-item"><div class="cart-emoji">'+c.emoji+'</div>'+
    '<div style="flex:1;min-width:0"><div style="font-weight:500;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+c.name+'</div><div style="color:var(--muted);font-size:12px">$'+c.price.toFixed(2)+' each</div></div>'+
    '<div class="qty-control"><button class="qty-btn" onclick="changeQty('+c.id+',-1)">−</button><span style="min-width:22px;text-align:center;font-size:13px">'+c.qty+'</span><button class="qty-btn" onclick="changeQty('+c.id+',1)">+</button></div>'+
    '<span style="font-weight:600;min-width:62px;text-align:right;margin-left:8px">$'+(c.price*c.qty).toFixed(2)+'</span>'+
    '<button onclick="removeFromCart('+c.id+')" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:18px;margin-left:8px;line-height:1" title="Remove">×</button></div>'
  ).join('');
  sum.innerHTML =
    '<div style="font-weight:600;margin-bottom:14px">Order Summary</div>'+
    '<div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:7px"><span style="color:var(--muted)">Subtotal ('+S.cart.reduce((a,c)=>a+c.qty,0)+' items)</span><span>$'+subtotal.toFixed(2)+'</span></div>'+
    '<div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:7px"><span style="color:var(--muted)">Shipping</span><span>'+(shipping===0?'<span class="tag tag-green">Free</span>':'$'+shipping.toFixed(2))+'</span></div>'+
    '<div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:14px"><span style="color:var(--muted)">Tax (8%)</span><span>$'+tax.toFixed(2)+'</span></div>'+
    '<div class="divider"></div>'+
    '<div style="display:flex;justify-content:space-between;font-weight:700;font-size:17px;margin:12px 0"><span>Total</span><span style="color:var(--accent)">$'+total.toFixed(2)+'</span></div>'+
    (subtotal<100?'<div style="font-size:11px;color:var(--muted);margin-bottom:12px">Add $'+(100-subtotal).toFixed(2)+' more for free shipping!</div>':'')+
    '<button class="btn btn-success btn-full" onclick="openCheckout()" style="padding:10px"><i class="ti ti-credit-card"></i> Proceed to Checkout</button>';
}

function changeQty(id, delta) {
  var ci = S.cart.find(c=>c.id===id);
  var prod = S.products.find(p=>p.id===id);
  if (!ci) return;
  ci.qty += delta;
  if (ci.qty<=0) S.cart = S.cart.filter(c=>c.id!==id);
  else if (prod && ci.qty>prod.stock) ci.qty = prod.stock;
  updateCartBadge(); renderCart();
}

function removeFromCart(id) {
  S.cart = S.cart.filter(c=>c.id!==id);
  updateCartBadge(); renderCart();
  showToast('🗑️ Item removed from cart');
}

function openCheckout() {
  if (!S.cart.length) { showToast('❌ Cart is empty'); return; }
  var subtotal = S.cart.reduce((a,c)=>a+c.price*c.qty, 0);
  var shipping = subtotal>=100 ? 0 : 9.99;
  var tax = subtotal*0.08;
  document.getElementById('chkSummary').innerHTML =
    '<div style="background:var(--bg3);border-radius:8px;padding:12px">'+
    '<div style="font-weight:600;font-size:13px;margin-bottom:8px">Order Items</div>'+
    S.cart.map(c=>'<div style="display:flex;justify-content:space-between;font-size:12px;color:var(--muted);padding:3px 0">'+
      '<span>'+c.emoji+' '+c.name+' ×'+c.qty+'</span><span>$'+(c.price*c.qty).toFixed(2)+'</span></div>').join('')+
    '<div class="divider"></div>'+
    '<div style="display:flex;justify-content:space-between;font-weight:700;font-size:14px">'+
    '<span>Total</span><span style="color:var(--accent)">$'+(subtotal+shipping+tax).toFixed(2)+'</span></div></div>';
  document.getElementById('checkoutModal').style.display = 'flex';
}

function placeOrder() {
  var items = S.cart.map(c=>({name:c.name,qty:c.qty,price:c.price,emoji:c.emoji}));
  var subtotal = S.cart.reduce((a,c)=>a+c.price*c.qty,0);
  var tax = subtotal*0.08;
  var shipping = subtotal>=100?0:9.99;
  var order = {
    id: 'ORD-00'+S.nextOrderId++,
    userId: S.currentUser,
    items: items,
    total: +(subtotal+tax+shipping).toFixed(2),
    status: 'Processing',
    date: new Date().toISOString().split('T')[0],
    addr: document.getElementById('chkAddr').value+', '+document.getElementById('chkCity').value
  };
  S.orders.push(order);
  var u = S.users.find(x=>x.email===S.currentUser);
  if (u) u.orders++;
  S.cart = [];
  updateCartBadge();
  closeModal('checkoutModal');
  showToast('✅ Order '+order.id+' placed successfully!');
  showSection('orders');
}

