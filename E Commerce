<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEXUS — E-Commerce Platform</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0a0a0f;--bg2:#12121a;--bg3:#1a1a26;--card:#1e1e2e;--border:#2a2a3e;--accent:#6c63ff;--accent2:#ff6b9d;--accent3:#00d9b4;--text:#e8e8f0;--muted:#888899;--danger:#ff4757;--success:#00d9b4;--warning:#ffa502}
html,body{height:100%;font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);font-size:14px}
.app{display:flex;flex-direction:column;min-height:100vh}
header{background:var(--bg2);border-bottom:1px solid var(--border);padding:12px 20px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.logo{font-size:20px;font-weight:800;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-0.5px}
.nav{display:flex;gap:4px;align-items:center}
.nav-btn{background:none;border:none;color:var(--muted);padding:7px 13px;border-radius:7px;cursor:pointer;font-size:13px;transition:all .2s;display:flex;align-items:center;gap:5px}
.nav-btn:hover,.nav-btn.active{background:var(--bg3);color:var(--text)}
.nav-btn.active{color:var(--accent)}
.badge{background:var(--accent2);color:#fff;border-radius:10px;padding:1px 7px;font-size:11px;font-weight:700;margin-left:2px}
.main{display:flex;flex:1}
.sidebar{width:210px;background:var(--bg2);border-right:1px solid var(--border);padding:16px 12px;display:flex;flex-direction:column;gap:3px;flex-shrink:0}
.sidebar-section{font-size:11px;color:var(--muted);margin:10px 0 5px 10px;letter-spacing:.6px;text-transform:uppercase}
.sidebar-item{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:7px;cursor:pointer;color:var(--muted);font-size:13px;transition:all .2s;border:none;background:none;text-align:left;width:100%}
.sidebar-item:hover{background:var(--bg3);color:var(--text)}
.sidebar-item.active{background:rgba(108,99,255,.15);color:var(--accent);border-left:2px solid var(--accent)}
.content{flex:1;padding:22px;overflow-y:auto;height:calc(100vh - 57px)}
.page{display:none}
.page.active{display:block}
.page-title{font-size:20px;font-weight:700;margin-bottom:18px;display:flex;align-items:center;gap:8px}
.grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.grid-4{display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:14px}
.card{background:var(--card);border:1px solid var(--border);border-radius:11px;padding:16px}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:11px;padding:16px}
.stat-val{font-size:26px;font-weight:700;margin-top:4px}
.stat-lbl{font-size:12px;color:var(--muted)}
.stat-up{font-size:11px;color:var(--success);margin-top:3px}
.product-card{background:var(--card);border:1px solid var(--border);border-radius:11px;overflow:hidden;transition:transform .2s,border-color .2s}
.product-card:hover{transform:translateY(-2px);border-color:var(--accent)}
.product-img{height:120px;display:flex;align-items:center;justify-content:center;font-size:42px;background:var(--bg3)}
.product-info{padding:13px}
.product-name{font-weight:600;font-size:13px;margin-bottom:3px}
.product-cat{color:var(--muted);font-size:11px;margin-bottom:7px}
.product-stock{font-size:11px;margin-bottom:9px}
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:7px;border:none;cursor:pointer;font-size:13px;font-weight:500;transition:all .2s}
.btn-primary{background:var(--accent);color:#fff}
.btn-primary:hover{background:#5a52e0}
.btn-danger{background:rgba(255,71,87,.15);color:var(--danger);border:1px solid rgba(255,71,87,.25)}
.btn-danger:hover{background:var(--danger);color:#fff}
.btn-sm{padding:5px 10px;font-size:12px}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--text)}
.btn-outline:hover{border-color:var(--accent);color:var(--accent)}
.btn-success{background:var(--success);color:#000;font-weight:600}
.btn-success:hover{opacity:.9}
.btn-full{width:100%;justify-content:center}
input,select,textarea{background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:8px 12px;border-radius:7px;font-size:13px;width:100%;outline:none;transition:border .2s;font-family:inherit}
input:focus,select:focus,textarea:focus{border-color:var(--accent)}
select option{background:var(--bg3)}
.form-group{margin-bottom:12px}
.form-label{font-size:12px;color:var(--muted);margin-bottom:5px;display:block}
.table{width:100%;border-collapse:collapse}
.table th{text-align:left;padding:10px 12px;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);white-space:nowrap}
.table td{padding:10px 12px;border-bottom:1px solid rgba(42,42,62,.5);font-size:13px;vertical-align:middle}
.table tr:hover td{background:rgba(108,99,255,.04)}
.tag{display:inline-block;padding:2px 9px;border-radius:5px;font-size:11px;font-weight:600}
.tag-purple{background:rgba(108,99,255,.2);color:#a09aff}
.tag-green{background:rgba(0,217,180,.15);color:#00d9b4}
.tag-red{background:rgba(255,71,87,.15);color:#ff6b7a}
.tag-orange{background:rgba(255,165,2,.15);color:#ffb830}
.tag-pink{background:rgba(255,107,157,.18);color:#ff85b5}
.tag-blue{background:rgba(56,139,253,.15);color:#79b8ff}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;display:flex;align-items:center;justify-content:center;padding:20px}
.modal{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:26px;width:100%;max-width:450px;max-height:90vh;overflow-y:auto}
.modal-title{font-size:16px;font-weight:700;margin-bottom:18px;display:flex;justify-content:space-between;align-items:center}
.close-btn{background:none;border:none;color:var(--muted);cursor:pointer;font-size:20px;line-height:1;padding:0 2px}
.close-btn:hover{color:var(--text)}
.login-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;background:var(--bg);padding:20px}
.login-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:34px;width:100%;max-width:370px;box-shadow:0 20px 60px rgba(0,0,0,.4)}
.login-logo{font-size:32px;font-weight:900;background:linear-gradient(135deg,var(--accent),var(--accent2),var(--accent3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-align:center;margin-bottom:4px;letter-spacing:-1px}
.login-sub{text-align:center;color:var(--muted);font-size:13px;margin-bottom:26px}
.role-switcher{display:flex;gap:8px;margin-bottom:20px}
.role-btn{flex:1;padding:9px;border-radius:8px;border:1px solid var(--border);background:none;color:var(--muted);cursor:pointer;font-size:13px;transition:all .2s}
.role-btn.active{border-color:var(--accent);background:rgba(108,99,255,.15);color:var(--accent);font-weight:600}
.divider{height:1px;background:var(--border);margin:14px 0}
.toast{position:fixed;bottom:22px;right:22px;background:var(--card);border:1px solid var(--border);border-radius:9px;padding:11px 18px;font-size:13px;z-index:500;animation:slideIn .3s ease;display:flex;align-items:center;gap:8px;box-shadow:0 8px 30px rgba(0,0,0,.3);max-width:320px}
@keyframes slideIn{from{transform:translateX(120px);opacity:0}to{transform:translateX(0);opacity:1}}
.cart-item{display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid rgba(42,42,62,.6)}
.cart-emoji{font-size:26px;width:44px;height:44px;background:var(--bg3);border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.qty-control{display:flex;align-items:center;gap:5px}
.qty-btn{width:26px;height:26px;border-radius:6px;border:1px solid var(--border);background:var(--bg3);color:var(--text);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;transition:border .2s}
.qty-btn:hover{border-color:var(--accent);color:var(--accent)}
.empty-state{text-align:center;padding:48px 20px;color:var(--muted)}
.empty-icon{font-size:44px;margin-bottom:14px}
.progress-bar{height:5px;background:var(--bg3);border-radius:3px;overflow:hidden;margin-top:5px}
.progress-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width .4s}
.chart-col{display:flex;flex-direction:column;align-items:center;gap:5px}
.chart-bar-fill{width:32px;background:linear-gradient(180deg,var(--accent),rgba(108,99,255,.3));border-radius:4px 4px 0 0;transition:height .6s}
.chart-row{display:flex;align-items:flex-end;gap:8px;height:90px;padding:0 6px;border-bottom:1px solid var(--border);border-left:1px solid var(--border)}
.chart-lbl{font-size:10px;color:var(--muted);width:32px;text-align:center}
.search-bar{display:flex;gap:8px;margin-bottom:16px}
.search-bar input{flex:1}
.hint-box{background:var(--bg3);border-radius:8px;padding:10px 13px;font-size:12px;color:var(--muted);margin-bottom:14px;line-height:1.6}
.order-steps{display:flex;margin-top:10px;margin-bottom:4px}
.order-step{flex:1;text-align:center}
.step-dot{width:11px;height:11px;border-radius:50%;margin:0 auto 4px;transition:background .3s}
.step-lbl{font-size:10px}
.action-row{display:flex;gap:6px}
</style>
</head>
<body>
<div class="app" id="app">

<!-- LOGIN -->
<div id="loginScreen" class="login-wrap">
  <div class="login-card">
    <div class="login-logo">NEXUS</div>
    <div class="login-sub">Premium E-Commerce Platform</div>
    <div class="role-switcher">
      <button class="role-btn active" onclick="setRole('user')" id="roleUserBtn">👤 Customer</button>
      <button class="role-btn" onclick="setRole('admin')" id="roleAdminBtn">🛡️ Admin</button>
    </div>
    <div class="form-group">
      <label class="form-label">Email</label>
      <input type="email" id="loginEmail" value="user@nexus.com">
    </div>
    <div class="form-group">
      <label class="form-label">Password</label>
      <input type="password" id="loginPass" value="password123">
    </div>
    <div class="hint-box" id="loginHint">
      👤 Customer — user@nexus.com / password123<br>
      🛡️ Admin — admin@nexus.com / admin123
    </div>
    <button class="btn btn-primary btn-full" onclick="doLogin()" style="padding:10px">Sign In →</button>
    <div style="text-align:center;font-size:12px;color:var(--muted);margin-top:14px">Demo credentials pre-filled above</div>
  </div>
</div>

<!-- MAIN APP -->
<div id="mainApp" style="display:none;flex-direction:column;min-height:100vh">
  <header>
    <div class="logo">NEXUS</div>
    <nav class="nav">
      <button class="nav-btn active" onclick="showSection('catalog')" id="nav-catalog"><i class="ti ti-layout-grid"></i> Shop</button>
      <button class="nav-btn" onclick="showSection('orders')" id="nav-orders"><i class="ti ti-package"></i> My Orders</button>
      <button class="nav-btn" onclick="showSection('cart')" id="nav-cart"><i class="ti ti-shopping-cart"></i> Cart<span class="badge" id="cartBadge">0</span></button>
    </nav>
    <div style="display:flex;align-items:center;gap:10px">
      <span style="font-size:12px;color:var(--muted)" id="userLabel"></span>
      <span id="roleBadge" class="tag"></span>
      <button class="btn btn-outline btn-sm" onclick="doLogout()">Sign out</button>
    </div>
  </header>

  <div class="main">
    <div class="sidebar">
      <div class="sidebar-section">Browse</div>
      <button class="sidebar-item active" onclick="filterCat('all')" id="cat-all"><i class="ti ti-category"></i> All Products</button>
      <button class="sidebar-item" onclick="filterCat('Electronics')" id="cat-Electronics"><i class="ti ti-device-laptop"></i> Electronics</button>
      <button class="sidebar-item" onclick="filterCat('Clothing')" id="cat-Clothing"><i class="ti ti-shirt"></i> Clothing</button>
      <button class="sidebar-item" onclick="filterCat('Books')" id="cat-Books"><i class="ti ti-book"></i> Books</button>
      <button class="sidebar-item" onclick="filterCat('Home')" id="cat-Home"><i class="ti ti-home"></i> Home & Living</button>
      <button class="sidebar-item" onclick="filterCat('Sports')" id="cat-Sports"><i class="ti ti-ball-football"></i> Sports</button>
      <div id="adminSidebar" style="display:none">
        <div class="divider"></div>
        <div class="sidebar-section">Admin</div>
        <button class="sidebar-item" onclick="showSection('dashboard')" id="sid-dashboard"><i class="ti ti-chart-bar"></i> Dashboard</button>
        <button class="sidebar-item" onclick="showSection('adminProducts')" id="sid-adminProducts"><i class="ti ti-packages"></i> Products</button>
        <button class="sidebar-item" onclick="showSection('adminOrders')" id="sid-adminOrders"><i class="ti ti-clipboard-list"></i> All Orders</button>
        <button class="sidebar-item" onclick="showSection('users')" id="sid-users"><i class="ti ti-users"></i> Users</button>
      </div>
    </div>

    <div class="content">

      <!-- CATALOG -->
      <div class="page active" id="page-catalog">
        <div class="page-title"><i class="ti ti-layout-grid"></i> Product Catalog</div>
        <div class="search-bar">
          <input type="text" id="searchInput" placeholder="Search products..." oninput="renderCatalog()">
          <select id="sortSelect" onchange="renderCatalog()" style="width:auto;min-width:140px">
            <option value="default">Default</option>
            <option value="price-asc">Price: Low → High</option>
            <option value="price-desc">Price: High → Low</option>
            <option value="name">Name A–Z</option>
          </select>
        </div>
        <div class="grid-4" id="productGrid"></div>
      </div>

      <!-- CART -->
      <div class="page" id="page-cart">
        <div class="page-title"><i class="ti ti-shopping-cart"></i> Shopping Cart</div>
        <div class="grid-2" style="gap:18px;align-items:start">
          <div id="cartItems"></div>
          <div class="card" id="orderSummary"></div>
        </div>
      </div>

      <!-- MY ORDERS -->
      <div class="page" id="page-orders">
        <div class="page-title"><i class="ti ti-package"></i> My Orders</div>
        <div id="myOrdersList"></div>
      </div>

      <!-- DASHBOARD -->
      <div class="page" id="page-dashboard">
        <div class="page-title"><i class="ti ti-chart-bar"></i> Admin Dashboard</div>
        <div class="grid-4" id="dashStats" style="margin-bottom:18px"></div>
        <div class="grid-2" style="gap:16px;margin-bottom:16px">
          <div class="card">
            <div style="font-weight:600;font-size:13px;margin-bottom:12px">Weekly Revenue</div>
            <div class="chart-row" id="revenueChart"></div>
            <div style="display:flex;gap:8px;margin-top:5px;justify-content:center" id="chartLabels"></div>
          </div>
          <div class="card">
            <div style="font-weight:600;font-size:13px;margin-bottom:12px">Top Categories by Revenue</div>
            <div id="topCats"></div>
          </div>
        </div>
        <div class="card">
          <div style="font-weight:600;font-size:13px;margin-bottom:12px">Recent Orders</div>
          <div style="overflow-x:auto" id="recentOrdersTable"></div>
        </div>
      </div>

      <!-- ADMIN PRODUCTS -->
      <div class="page" id="page-adminProducts">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px">
          <div class="page-title" style="margin:0"><i class="ti ti-packages"></i> Manage Products</div>
          <button class="btn btn-primary" onclick="openProductModal()"><i class="ti ti-plus"></i> Add Product</button>
        </div>
        <div style="overflow-x:auto" id="adminProductTable"></div>
      </div>

      <!-- ADMIN ORDERS -->
      <div class="page" id="page-adminOrders">
        <div class="page-title"><i class="ti ti-clipboard-list"></i> All Orders</div>
        <div style="overflow-x:auto" id="allOrdersTable"></div>
      </div>

      <!-- USERS -->
      <div class="page" id="page-users">
        <div class="page-title"><i class="ti ti-users"></i> User Management</div>
        <div style="overflow-x:auto" id="usersTable"></div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->
</div><!-- /mainApp -->

<!-- MODAL: Add/Edit Product -->
<div class="modal-overlay" id="productModal" style="display:none" onclick="handleOverlay(event,'productModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-title"><span id="productModalTitle">Add Product</span><button class="close-btn" onclick="closeModal('productModal')">✕</button></div>
    <div class="form-group"><label class="form-label">Product Name</label><input id="pName" placeholder="e.g. Wireless Headphones"></div>
    <div class="grid-2">
      <div class="form-group"><label class="form-label">Price ($)</label><input id="pPrice" type="number" step="0.01" placeholder="29.99"></div>
      <div class="form-group"><label class="form-label">Stock</label><input id="pStock" type="number" placeholder="100"></div>
    </div>
    <div class="form-group"><label class="form-label">Category</label>
      <select id="pCat"><option>Electronics</option><option>Clothing</option><option>Books</option><option>Home</option><option>Sports</option></select>
    </div>
    <div class="form-group"><label class="form-label">Emoji Icon</label><input id="pEmoji" placeholder="📦" value="📦"></div>
    <div class="form-group"><label class="form-label">Description</label><textarea id="pDesc" rows="2" style="resize:none" placeholder="Short description..."></textarea></div>
    <div class="grid-2" style="gap:8px;margin-top:4px">
      <button class="btn btn-primary btn-full" onclick="saveProduct()" id="saveProductBtn">Add Product</button>
      <button class="btn btn-outline btn-full" onclick="closeModal('productModal')">Cancel</button>
    </div>
  </div>
</div>

<!-- MODAL: Checkout -->
<div class="modal-overlay" id="checkoutModal" style="display:none" onclick="handleOverlay(event,'checkoutModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-title">Checkout <button class="close-btn" onclick="closeModal('checkoutModal')">✕</button></div>
    <div style="font-size:13px;font-weight:600;margin-bottom:10px">Shipping Information</div>
    <div class="form-group"><label class="form-label">Full Name</label><input id="chkName" value="John Doe"></div>
    <div class="form-group"><label class="form-label">Address</label><input id="chkAddr" value="123 Main Street"></div>
    <div class="grid-2">
      <div class="form-group"><label class="form-label">City</label><input id="chkCity" value="San Francisco"></div>
      <div class="form-group"><label class="form-label">ZIP</label><input id="chkZip" value="94102"></div>
    </div>
    <div class="divider"></div>
    <div style="font-size:13px;font-weight:600;margin-bottom:10px">Payment Details</div>
    <div class="form-group"><label class="form-label">Card Number</label><input id="chkCard" value="4242 4242 4242 4242"></div>
    <div class="grid-2">
      <div class="form-group"><label class="form-label">Expiry</label><input id="chkExp" value="12/26"></div>
      <div class="form-group"><label class="form-label">CVV</label><input id="chkCvv" type="password" value="123"></div>
    </div>
    <div class="divider"></div>
    <div id="chkSummary" style="margin-bottom:16px"></div>
    <button class="btn btn-success btn-full" onclick="placeOrder()" style="padding:11px"><i class="ti ti-check"></i> Place Order</button>
  </div>
</div>

<!-- MODAL: Order Detail -->
<div class="modal-overlay" id="orderDetailModal" style="display:none" onclick="handleOverlay(event,'orderDetailModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-title">Order Details <button class="close-btn" onclick="closeModal('orderDetailModal')">✕</button></div>
    <div id="orderDetailContent"></div>
  </div>
</div>

<!-- MODAL: Update Status -->
<div class="modal-overlay" id="updateStatusModal" style="display:none" onclick="handleOverlay(event,'updateStatusModal')">
  <div class="modal" style="max-width:340px" onclick="event.stopPropagation()">
    <div class="modal-title">Update Order Status <button class="close-btn" onclick="closeModal('updateStatusModal')">✕</button></div>
    <div class="form-group">
      <label class="form-label">New Status</label>
      <select id="newStatusSelect">
        <option value="Processing">Processing</option>
        <option value="Shipped">Shipped</option>
        <option value="Delivered">Delivered</option>
        <option value="Cancelled">Cancelled</option>
      </select>
    </div>
    <input type="hidden" id="statusOrderId">
    <button class="btn btn-primary btn-full" onclick="confirmStatusUpdate()" style="margin-top:4px">Update Status</button>
  </div>
</div>

<!-- TOAST -->
<div id="toastEl" class="toast" style="display:none"></div>

<script>
/* ===== STATE ===== */
var S = {
  role: 'user',
  currentUser: null,
  section: 'catalog',
  catFilter: 'all',
  cart: [],
  editingProductId: null,
  nextOrderId: 5,
  nextProductId: 13,
  products: [
    {id:1,name:'Wireless Headphones',price:89.99,stock:45,cat:'Electronics',emoji:'🎧',desc:'Premium audio with active noise cancellation and 30-hour battery life.'},
    {id:2,name:'Smart Watch Pro',price:199.99,stock:12,cat:'Electronics',emoji:'⌚',desc:'Track health metrics, notifications, and GPS with always-on display.'},
    {id:3,name:'Laptop Stand',price:34.99,stock:78,cat:'Electronics',emoji:'💻',desc:'Ergonomic aluminium laptop stand with adjustable height.'},
    {id:4,name:'Bluetooth Speaker',price:49.99,stock:0,cat:'Electronics',emoji:'🔊',desc:'360° immersive sound with 12-hour battery and IPX5 water resistance.'},
    {id:5,name:'Running Shoes',price:120.00,stock:30,cat:'Sports',emoji:'👟',desc:'Lightweight performance running shoes with responsive foam cushioning.'},
