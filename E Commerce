      '<td><span class="tag '+(p.stock>20?'tag-green':p.stock>0?'tag-orange':'tag-red')+'">'+(p.stock>20?'In Stock':p.stock>0?'Low Stock':'Out of Stock')+'</span></td>'+
      '<td><div class="action-row"><button class="btn btn-outline btn-sm" onclick="editProduct('+p.id+')"><i class="ti ti-edit"></i> Edit</button><button class="btn btn-danger btn-sm" onclick="deleteProduct('+p.id+')"><i class="ti ti-trash"></i></button></div></td></tr>'
    ).join('')+'</tbody></table>';
}

function openProductModal(id) {
  S.editingProductId = id || null;
  var p = id ? S.products.find(x=>x.id===id) : null;
  document.getElementById('productModalTitle').textContent = p ? 'Edit Product' : 'Add Product';
  document.getElementById('saveProductBtn').textContent = p ? 'Save Changes' : 'Add Product';
  document.getElementById('pName').value  = p ? p.name  : '';
  document.getElementById('pPrice').value = p ? p.price : '';
  document.getElementById('pStock').value = p ? p.stock : '';
  document.getElementById('pCat').value   = p ? p.cat   : 'Electronics';
  document.getElementById('pEmoji').value = p ? p.emoji : '📦';
  document.getElementById('pDesc').value  = p ? p.desc  : '';
  document.getElementById('productModal').style.display = 'flex';
}

function editProduct(id) { openProductModal(id); }

function saveProduct() {
  var name  = document.getElementById('pName').value.trim();
  var price = parseFloat(document.getElementById('pPrice').value);
  var stock = parseInt(document.getElementById('pStock').value);
  var cat   = document.getElementById('pCat').value;
  var emoji = document.getElementById('pEmoji').value.trim() || '📦';
  var desc  = document.getElementById('pDesc').value.trim();
  if (!name || isNaN(price) || isNaN(stock)) { showToast('❌ Please fill all required fields'); return; }
  if (S.editingProductId) {
    var p = S.products.find(x=>x.id===S.editingProductId);
    if (p) Object.assign(p, {name,price,stock,cat,emoji,desc});
    showToast('✅ Product updated successfully');
  } else {
    S.products.push({id:S.nextProductId++, name, price, stock, cat, emoji, desc});
    showToast('✅ Product added to catalog');
  }
  closeModal('productModal');
  renderAdminProducts();
  renderCatalog();
}

function deleteProduct(id) {
  if (!confirm('Delete this product?')) return;
  S.products = S.products.filter(p=>p.id!==id);
  S.cart = S.cart.filter(c=>c.id!==id);
  updateCartBadge();
  renderAdminProducts(); renderCatalog();
  showToast('🗑️ Product deleted');
}

/* ===== ADMIN ORDERS ===== */
function renderAllOrders() {
  var el = document.getElementById('allOrdersTable');
  if (!el) return;
  el.innerHTML = '<table class="table"><thead><tr><th>Order ID</th><th>Customer</th><th>Date</th><th>Items</th><th>Total</th><th>Status</th><th>Actions</th></tr></thead><tbody>'+
    S.orders.slice().reverse().map(o=>
      '<tr>'+
      '<td style="font-weight:600">'+o.id+'</td>'+
      '<td style="color:var(--muted)">'+o.userId+'</td>'+
      '<td style="font-size:12px;color:var(--muted)">'+o.date+'</td>'+
      '<td>'+o.items.map(i=>i.emoji).join(' ')+' ('+o.items.length+')</td>'+
      '<td style="font-weight:600;color:var(--accent)">$'+o.total.toFixed(2)+'</td>'+
      '<td><span class="tag '+statusTag(o.status)+'">'+o.status+'</span></td>'+
      '<td><div class="action-row"><button class="btn btn-outline btn-sm" onclick="viewOrderDetail(\''+o.id+'\')">View</button><button class="btn btn-primary btn-sm" onclick="openStatusModal(\''+o.id+'\')">Update</button></div></td></tr>'
    ).join('')+'</tbody></table>';
}

function openStatusModal(id) {
  document.getElementById('statusOrderId').value = id;
  var o = S.orders.find(x=>x.id===id);
  if (o) document.getElementById('newStatusSelect').value = o.status;
  document.getElementById('updateStatusModal').style.display = 'flex';
}

function confirmStatusUpdate() {
  var id = document.getElementById('statusOrderId').value;
  var status = document.getElementById('newStatusSelect').value;
  var o = S.orders.find(x=>x.id===id);
  if (o) { o.status = status; showToast('✅ '+id+' status → '+status); }
  closeModal('updateStatusModal');
  renderAllOrders(); renderDashboard();
}

/* ===== USERS ===== */
function renderUsers() {
  var el = document.getElementById('usersTable');
  if (!el) return;
  el.innerHTML = '<table class="table"><thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Orders</th><th>Joined</th><th>Action</th></tr></thead><tbody>'+
    S.users.map(u=>
      '<tr>'+
      '<td style="font-weight:500">'+u.name+'</td>'+
      '<td style="color:var(--muted)">'+u.email+'</td>'+
      '<td><span class="tag '+(u.role==='Admin'?'tag-pink':'tag-purple')+'">'+u.role+'</span></td>'+
      '<td>'+u.orders+'</td>'+
      '<td style="font-size:12px;color:var(--muted)">'+u.joined+'</td>'+
      '<td><button class="btn btn-outline btn-sm" onclick="toggleRole(\''+u.email+'\')">Make '+(u.role==='Admin'?'User':'Admin')+'</button></td></tr>'
    ).join('')+'</tbody></table>';
}

function toggleRole(email) {
  var u = S.users.find(x=>x.email===email);
  if (u) { u.role = u.role==='Admin' ? 'User' : 'Admin'; showToast('✅ '+u.name+' is now '+u.role); renderUsers(); }
}

/* ===== HELPERS ===== */
function statusTag(s) {
  return {Delivered:'tag-green',Shipped:'tag-purple',Processing:'tag-orange',Cancelled:'tag-red'}[s] || 'tag-orange';
}

function closeModal(id) { document.getElementById(id).style.display = 'none'; }
function handleOverlay(e, id) { if (e.target.id===id) closeModal(id); }

var _toastTimer;
function showToast(msg) {
  var el = document.getElementById('toastEl');
  el.textContent = msg;
  el.style.display = 'flex';
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(()=>{ el.style.display='none'; }, 2800);
}
</script>
</body>
</html>
