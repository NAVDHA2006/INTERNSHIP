    <div class="modal-footer">
      <button class="btn btn-outline btn-sm" onclick="closeModal('taskModal')">CANCEL</button>
      <button class="btn btn-accent btn-sm" onclick="saveTask()" id="saveTaskBtn">CREATE TASK</button>
