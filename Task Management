</div>

<script>
/* ═══════════════════════════════════════════
   STATE
═══════════════════════════════════════════ */
var APP = {
  currentUser: null,
  view: 'board',
  filter: 'all',
  search: '',
  filterPriority: 'all',
  editingTaskId: null,
  nextId: 100,
  ws: null,

  users: [
    {id:'u1', name:'Alice Chen',   email:'alice@taskflow.io', password:'password', role:'Admin',  color:'#e63946'},
    {id:'u2', name:'Bob Torres',   email:'bob@taskflow.io',   password:'password', role:'Member', color:'#457b9d'},
    {id:'u3', name:'Sara Kim',     email:'sara@taskflow.io',  password:'password', role:'Member', color:'#2a9d8f'},
    {id:'u4', name:'Dev Patel',    email:'dev@taskflow.io',   password:'password', role:'Member', color:'#f4a261'},
  ],

  tasks: [
    {id:'t1',  title:'Design new landing page',       desc:'Revamp the homepage with fresh UI. Focus on conversion and clarity.',   priority:'critical', status:'inprogress', assigneeId:'u1', due:'2025-05-28', tags:['design','frontend'], created:'2025-05-01', comments:['Figma file shared','Reviewed by PM']},
    {id:'t2',  title:'Set up CI/CD pipeline',         desc:'Configure GitHub Actions for automated tests and deployment.',           priority:'high',     status:'todo',       assigneeId:'u2', due:'2025-06-05', tags:['devops','backend'],  created:'2025-05-03', comments:[]},
    {id:'t3',  title:'Write API documentation',       desc:'Document all REST endpoints using OpenAPI 3.0 spec.',                    priority:'medium',   status:'review',     assigneeId:'u3', due:'2025-06-10', tags:['docs'],              created:'2025-05-05', comments:['Draft complete']},
    {id:'t4',  title:'Fix auth token expiry bug',     desc:'Tokens sometimes expire prematurely. Investigate JWT refresh logic.',    priority:'critical', status:'inprogress', assigneeId:'u2', due:'2025-05-27', tags:['bug','backend'],    created:'2025-05-06', comments:['Root cause found']},
    {id:'t5',  title:'User onboarding flow',          desc:'Build step-by-step onboarding wizard for new signups.',                  priority:'high',     status:'todo',       assigneeId:'u1', due:'2025-06-15', tags:['ux','frontend'],    created:'2025-05-07', comments:[]},
    {id:'t6',  title:'Database indexing audit',       desc:'Audit slow queries and add missing indexes on production DB.',           priority:'high',     status:'done',       assigneeId:'u4', due:'2025-05-20', tags:['backend','db'],     created:'2025-04-28', comments:['Completed, 40% perf gain']},
    {id:'t7',  title:'Mobile responsive fixes',       desc:'Fix layout issues on screens below 400px width.',                       priority:'medium',   status:'done',       assigneeId:'u3', due:'2025-05-22', tags:['frontend'],         created:'2025-04-30', comments:[]},
    {id:'t8',  title:'Integrate payment gateway',     desc:'Add Stripe for subscription billing. Handle webhooks properly.',         priority:'critical', status:'todo',       assigneeId:'u1', due:'2025-06-01', tags:['payments','backend'],created:'2025-05-08', comments:[]},
    {id:'t9',  title:'Analytics dashboard',           desc:'Build real-time analytics using Chart.js. Show DAU, revenue, funnels.',  priority:'medium',   status:'inprogress', assigneeId:'u4', due:'2025-06-20', tags:['analytics'],       created:'2025-05-10', comments:[]},
    {id:'t10', title:'Security audit & pen test',     desc:'Engage external team for penetration testing. Review OWASP top 10.',    priority:'high',     status:'review',     assigneeId:'u2', due:'2025-06-08', tags:['security'],         created:'2025-05-11', comments:['Booked for June 6']},
    {id:'t11', title:'Migrate to TypeScript',         desc:'Convert core modules to TypeScript for better type safety.',             priority:'low',      status:'todo',       assigneeId:'u4', due:'2025-07-01', tags:['refactor'],         created:'2025-05-12', comments:[]},
    {id:'t12', title:'Email notification system',     desc:'Send automated emails for task assignments, due dates, and mentions.',   priority:'medium',   status:'todo',       assigneeId:'u3', due:'2025-06-25', tags:['backend','email'],  created:'2025-05-13', comments:[]},
  ],

  feedLog: []
};

var STATUSES = {
  todo:       {label:'TODO',        col:'todo'},
  inprogress: {label:'IN PROGRESS', col:'inprogress'},
  review:     {label:'IN REVIEW',   col:'review'},
  done:       {label:'DONE',        col:'done'}
};

/* ═══════════════════════════════════════════
   AUTH
═══════════════════════════════════════════ */
function authTab(t) {
  document.getElementById('tabLogin').className    = 'auth-tab' + (t==='login'    ? ' active' : '');
  document.getElementById('tabRegister').className = 'auth-tab' + (t==='register' ? ' active' : '');
  document.getElementById('loginForm').style.display    = t==='login'    ? '' : 'none';
  document.getElementById('registerForm').style.display = t==='register' ? '' : 'none';
}

function doLogin() {
  var em = v('loginEmail').trim().toLowerCase();
  var pw = v('loginPass');
  var u  = APP.users.find(x=>x.email.toLowerCase()===em && x.password===pw);
  if (!u) { toast('Invalid credentials','error'); return; }
  loginSuccess(u);
}

function doRegister() {
  var name = v('regName').trim();
  var em   = v('regEmail').trim().toLowerCase();
  var pw   = v('regPass');
  var role = v('regRole');
  if (!name||!em||pw.length<6) { toast('Fill all fields (password ≥ 6 chars)','warn'); return; }
  if (APP.users.find(x=>x.email.toLowerCase()===em)) { toast('Email already registered','error'); return; }
  var colors = ['#e63946','#457b9d','#2a9d8f','#f4a261','#a8dadc'];
  var u = {id:'u'+Date.now(), name, email:em, password:pw, role, color:colors[APP.users.length%colors.length]};
  APP.users.push(u);
  toast('Account created! Signing in…','success');
  setTimeout(()=>loginSuccess(u), 500);
}

function loginSuccess(u) {
  APP.currentUser = u;
  document.getElementById('authScreen').style.display = 'none';
  document.getElementById('mainApp').style.display = 'flex';
  el('headerAvatar').textContent = initials(u.name);
  el('headerName').textContent   = u.name.split(' ')[0];
  el('headerRole').textContent   = '['+u.role.toUpperCase()+']';
  el('sidebarAvatar').textContent = initials(u.name);
  el('sidebarAvatar').style.background = u.color;
  el('headerAvatar').style.background  = u.color;
  el('sidebarName').textContent = u.name;
  el('sidebarRole').textContent = u.role.toUpperCase();
  updateSidebarCounts();
  renderTeam();
  showView('board');
  startFakeWS();
  toast('Welcome back, '+u.name.split(' ')[0]+'!','success');
}

function doLogout() {
  APP.currentUser = null;
  if (APP.wsTimer) clearInterval(APP.wsTimer);
  document.getElementById('mainApp').style.display = 'none';
  document.getElementById('authScreen').style.display = 'flex';
}

/* ═══════════════════════════════════════════
   NAVIGATION
═══════════════════════════════════════════ */
function showView(v) {
  APP.view = v;
  ['board','list','dashboard'].forEach(x=>{
    var nb = el('nav-'+x);
    if (nb) nb.className = 'sidebar-item' + (x===v?' active':'');
  });
  render();
}

function setFilter(f) {
  APP.filter = f;
  ['my','overdue','critical','all'].forEach(x=>{
    var nb = el('filt-'+x);
    if (nb) nb.className = 'sidebar-item' + (x===f?' active':'');
  });
  render();
}

/* ═══════════════════════════════════════════
   DATA HELPERS
═══════════════════════════════════════════ */
function getFilteredTasks() {
  var u = APP.currentUser;
  var today = todayStr();
  return APP.tasks.filter(t=>{
    if (APP.filter==='my'       && t.assigneeId!==u.id) return false;
    if (APP.filter==='overdue'  && (t.due>=today||t.status==='done')) return false;
    if (APP.filter==='critical' && t.priority!=='critical') return false;
    if (APP.search && !t.title.toLowerCase().includes(APP.search) && !(t.desc||'').toLowerCase().includes(APP.search)) return false;
    if (APP.filterPriority!=='all' && t.priority!==APP.filterPriority) return false;
    return true;
  });
}

function getUser(id) { return APP.users.find(u=>u.id===id)||{name:'Unassigned',color:'#8a8578',id:''} }
function todayStr() { return new Date().toISOString().split('T')[0]; }
function initials(name) { return name.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase(); }
function isOverdue(t) { return t.due && t.due < todayStr() && t.status!=='done'; }

function priorityLabel(p) {
  return {critical:'CRITICAL',high:'HIGH',medium:'MEDIUM',low:'LOW'}[p]||p.toUpperCase();
}
function priorityClass(p) {
  return {critical:'p-critical',high:'p-high',medium:'p-medium',low:'p-low'}[p]||'p-medium';
}

function updateSidebarCounts() {
  var u = APP.currentUser; if(!u) return;
  var today = todayStr();
  var all = APP.tasks;
  el('cnt-board').textContent    = all.filter(t=>t.status!=='done').length;
  el('cnt-my').textContent       = all.filter(t=>t.assigneeId===u.id&&t.status!=='done').length;
  el('cnt-overdue').textContent  = all.filter(t=>t.due<today&&t.status!=='done').length;
  el('cnt-critical').textContent = all.filter(t=>t.priority==='critical'&&t.status!=='done').length;
  var myPending = all.filter(t=>t.assigneeId===u.id&&t.status!=='done').length;
  var overdue   = all.filter(t=>t.due<today&&t.status!=='done').length;
  el('cnt-my').className      = 'sidebar-count' + (myPending>0?' hot':'');
  el('cnt-overdue').className = 'sidebar-count' + (overdue>0?' hot':'');
}

function renderTeam() {
  var html = APP.users.map(u=>'<div style="display:flex;align-items:center;gap:7px;padding:5px 6px;font-size:11px;color:var(--muted)">'+
    '<div style="width:20px;height:20px;border-radius:50%;background:'+u.color+';display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;flex-shrink:0">'+initials(u.name)+'</div>'+
    '<span style="color:var(--ink)">'+u.name.split(' ')[0]+'</span>'+
    '<span style="font-size:10px;margin-left:auto">'+u.role+'</span></div>'
  ).join('');
  el('teamList').innerHTML = html;
}

/* ═══════════════════════════════════════════
   MAIN RENDER
═══════════════════════════════════════════ */
function render() {
  if (APP.view==='board')     renderBoard();
  else if (APP.view==='list') renderList();
  else                        renderDashboard();
  updateSidebarCounts();
}

/* ─── TOOLBAR ─── */
function toolbarHTML(title, extraBtn) {
  return '<div class="toolbar">'+
    '<div class="toolbar-title">'+title+'</div>'+
    '<div class="view-toggle">'+
      '<button class="view-btn'+(APP.view==='board'?' active':'')+'" onclick="showView(\'board\')">⬛ BOARD</button>'+
      '<button class="view-btn'+(APP.view==='list'?' active':'')+'" onclick="showView(\'list\')">☰ LIST</button>'+
      '<button class="view-btn'+(APP.view==='dashboard'?' active':'')+'" onclick="showView(\'dashboard\')">◈ STATS</button>'+
    '</div>'+
    '<input class="search-input" placeholder="Search tasks…" value="'+APP.search+'" oninput="APP.search=this.value;render()">'+
    '<select class="filter-select" onchange="APP.filterPriority=this.value;render()">'+
      '<option value="all"'+(APP.filterPriority==='all'?' selected':'')+'>ALL PRIORITY</option>'+
      '<option value="critical"'+(APP.filterPriority==='critical'?' selected':'')+'>CRITICAL</option>'+
      '<option value="high"'+(APP.filterPriority==='high'?' selected':'')+'>HIGH</option>'+
      '<option value="medium"'+(APP.filterPriority==='medium'?' selected':'')+'>MEDIUM</option>'+
      '<option value="low"'+(APP.filterPriority==='low'?' selected':'')+'>LOW</option>'+
    '</select>'+
    '<button class="btn btn-accent btn-sm" onclick="openTaskModal()">+ NEW TASK</button>'+
  '</div>';
}

/* ─── BOARD VIEW ─── */
function renderBoard() {
  var tasks = getFilteredTasks();
  var cols  = ['todo','inprogress','review','done'];
  var colCfg = {
    todo:       {label:'TO DO',       cls:'todo'},
    inprogress: {label:'IN PROGRESS', cls:'inprogress'},
    review:     {label:'REVIEW',      cls:'review'},
    done:       {label:'DONE',        cls:'done'}
  };
  var colsHTML = cols.map(col=>{
    var colTasks = tasks.filter(t=>t.status===col);
    var cardsHTML = colTasks.map(t=>taskCardHTML(t)).join('');
    var canAdd = col==='todo' || col==='inprogress';
    return '<div class="board-col">'+
      '<div class="col-header '+colCfg[col].cls+'">'+
        '<div class="col-title">'+colCfg[col].label+'</div>'+
        '<div class="col-count">'+colTasks.length+'</div>'+
      '</div>'+
      '<div class="col-drop-zone" id="drop-'+col+'" ondragover="dragOver(event,\''+col+'\')" ondragleave="dragLeave(event)" ondrop="dropTask(event,\''+col+'\')" style="display:flex;flex-direction:column;gap:10px;min-height:60px">'+
      cardsHTML+'</div>'+
      (canAdd?'<button class="add-task-btn" onclick="openTaskModal(\''+col+'\')">+ ADD TASK</button>':'')+
    '</div>';
  }).join('');
  el('mainContent').innerHTML = toolbarHTML('KANBAN BOARD')+'<div class="board" style="overflow-x:auto">'+colsHTML+'</div>';
}

function taskCardHTML(t) {
  var u     = getUser(t.assigneeId);
  var od    = isOverdue(t);
  var dueLabel = t.due ? (od?'⚠ ':'')+(t.due.substring(5)) : '';
  var tagsHTML  = (t.tags||[]).map(tg=>'<span class="task-tag">'+tg+'</span>').join('');
  return '<div class="task-card" draggable="true" ondragstart="dragStart(event,\''+t.id+'\')" id="tc-'+t.id+'" onclick="viewTask(\''+t.id+'\')">'+
    '<div class="task-actions">'+
      '<button class="btn btn-sm" onclick="event.stopPropagation();openTaskModal(null,\''+t.id+'\')" title="Edit" style="padding:3px 7px;font-size:10px">✎</button>'+
      '<button class="btn btn-danger btn-sm" onclick="event.stopPropagation();confirmDelete(\''+t.id+'\')" title="Delete" style="padding:3px 7px;font-size:10px">✕</button>'+
    '</div>'+
    '<div class="task-title">'+esc(t.title)+'</div>'+
    (t.desc?'<div class="task-desc">'+esc(t.desc)+'</div>':'')+
    '<div class="task-meta">'+
      '<span class="priority-tag '+priorityClass(t.priority)+'">'+priorityLabel(t.priority)+'</span>'+
      tagsHTML+
      '<span class="task-due'+(od?' overdue':'')+'">'+
        '<div class="task-assignee" style="background:'+u.color+'">'+initials(u.name)+'</div>'+
        (dueLabel?'📅 '+dueLabel:'')+'</span>'+
    '</div>'+
  '</div>';
}

/* ─── LIST VIEW ─── */
function renderList() {
  var tasks = getFilteredTasks();
  var today = todayStr();
  var rowsHTML = tasks.length===0
    ? '<div class="empty-state"><div class="empty-icon">◈</div><p>No tasks match current filter.</p></div>'
    : tasks.map(t=>{
      var u  = getUser(t.assigneeId);
      var od = isOverdue(t);
      return '<div class="list-row'+(t.status==='done'?' done-row':'')+'" onclick="viewTask(\''+t.id+'\')" id="lr-'+t.id+'">'+
        '<div style="display:flex;align-items:center;gap:8px">'+
          '<div class="task-assignee" style="background:'+u.color+'">'+initials(u.name)+'</div>'+
          '<span class="task-title-list" style="font-size:13px;font-weight:600">'+esc(t.title)+'</span>'+
        '</div>'+
        '<span class="priority-tag '+priorityClass(t.priority)+'" style="font-size:10px">'+priorityLabel(t.priority).substring(0,3)+'</span>'+
        '<span class="badge" style="font-size:10px;background:var(--paper2);border:1px solid var(--border)">'+STATUSES[t.status].label+'</span>'+
        '<span class="hide-mob" style="font-size:11px;color:'+(od?'var(--accent)':'var(--muted)')+'">'+
          (t.due?(od?'⚠ ':'')+t.due.substring(5):'—')+'</span>'+
        '<div style="display:flex;gap:5px;align-items:center" class="hide-mob">'+
          '<button class="btn btn-sm btn-outline" onclick="event.stopPropagation();openTaskModal(null,\''+t.id+'\')" style="padding:3px 8px;font-size:10px">✎</button>'+
          '<button class="btn btn-sm btn-danger" onclick="event.stopPropagation();confirmDelete(\''+t.id+'\')" style="padding:3px 8px;font-size:10px">✕</button>'+
        '</div>'+
      '</div>';
    }).join('');

  el('mainContent').innerHTML = toolbarHTML('TASK LIST')+
    '<div class="list-view">'+
      '<div class="list-header"><span>TASK</span><span>PRIORITY</span><span>STATUS</span><span class="hide-mob">DUE</span><span class="hide-mob">ACTIONS</span></div>'+
      rowsHTML+
    '</div>';
}

/* ─── DASHBOARD ─── */
function renderDashboard() {
  var all   = APP.tasks;
  var today = todayStr();
  var done  = all.filter(t=>t.status==='done').length;
  var total = all.length;
  var over  = all.filter(t=>t.due<today&&t.status!=='done').length;
  var inp   = all.filter(t=>t.status==='inprogress').length;
  var crit  = all.filter(t=>t.priority==='critical'&&t.status!=='done').length;
  var pct   = total>0?Math.round(done/total*100):0;

  // Per-user stats
  var userStats = APP.users.map(u=>({
    u, total: all.filter(t=>t.assigneeId===u.id).length,
    done:  all.filter(t=>t.assigneeId===u.id&&t.status==='done').length,
    open:  all.filter(t=>t.assigneeId===u.id&&t.status!=='done').length,
  })).filter(x=>x.total>0);

  // Recent activity — last 5 tasks sorted by id desc
  var recent = all.slice().sort((a,b)=>b.id>a.id?1:-1).slice(0,5);

  el('mainContent').innerHTML = toolbarHTML('DASHBOARD')+
    '<div class="stats-grid">'+
      statCard('c-green',  done,    'COMPLETED', pct+'% done')+
      statCard('c-red',    over,    'OVERDUE',   'need attention')+
      statCard('c-blue',   inp,     'IN PROGRESS','active tasks')+
      statCard('c-warn',   crit,    'CRITICAL',  'high urgency')+
    '</div>'+
    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px">'+
      '<div class="stat-card">'+
        '<div class="stat-lbl">OVERALL COMPLETION</div>'+
        '<div style="font-family:var(--font-head);font-size:28px;font-weight:800;margin:6px 0">'+pct+'%</div>'+
        '<div class="progress-bar" style="height:6px"><div class="progress-fill" style="width:'+pct+'%"></div></div>'+
        '<div class="stat-sub">'+done+' of '+total+' tasks complete</div>'+
      '</div>'+
      '<div class="stat-card">'+
        '<div class="stat-lbl">TASKS BY STATUS</div>'+
        ['todo','inprogress','review','done'].map(s=>{
          var cnt = all.filter(t=>t.status===s).length;
          var pct2 = total>0?Math.round(cnt/total*100):0;
          return '<div style="display:flex;align-items:center;gap:8px;margin-top:8px;font-size:11px">'+
            '<span style="min-width:90px;color:var(--muted)">'+STATUSES[s].label+'</span>'+
            '<div style="flex:1;height:6px;background:var(--paper3);border-radius:3px;overflow:hidden"><div style="height:100%;background:var(--accent2);width:'+pct2+'%"></div></div>'+
            '<span style="min-width:22px;text-align:right">'+cnt+'</span></div>';
        }).join('')+
      '</div>'+
    '</div>'+
    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">'+
      '<div class="stat-card">'+
        '<div class="stat-lbl" style="margin-bottom:12px">TEAM WORKLOAD</div>'+
        userStats.map(x=>'<div style="display:flex;align-items:center;gap:9px;margin-bottom:10px">'+
          '<div class="user-avatar" style="background:'+x.u.color+';width:26px;height:26px;font-size:10px;flex-shrink:0">'+initials(x.u.name)+'</div>'+
          '<div style="flex:1;min-width:0">'+
            '<div style="font-size:11px;font-weight:700;margin-bottom:3px">'+x.u.name.split(' ')[0]+' <span style="font-weight:400;color:var(--muted)">('+x.open+' open)</span></div>'+
            '<div class="progress-bar"><div class="progress-fill" style="width:'+(x.total?Math.round(x.done/x.total*100):0)+'%;background:'+x.u.color+'"></div></div>'+
          '</div>'+
        '</div>').join('')+
      '</div>'+
      '<div class="stat-card">'+
        '<div class="stat-lbl" style="margin-bottom:12px">RECENT TASKS</div>'+
        recent.map(t=>{
          var u=getUser(t.assigneeId);
          return '<div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--paper3);cursor:pointer" onclick="viewTask(\''+t.id+'\')" >'+
            '<div class="user-avatar" style="background:'+u.color+';width:22px;height:22px;font-size:9px;flex-shrink:0">'+initials(u.name)+'</div>'+
            '<span style="flex:1;font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+esc(t.title)+'</span>'+
            '<span class="priority-tag '+priorityClass(t.priority)+'" style="font-size:9px">'+priorityLabel(t.priority).substring(0,3)+'</span>'+
          '</div>';
        }).join('')+
      '</div>'+
    '</div>';
}

function statCard(cls, num, lbl, sub) {
  return '<div class="stat-card '+cls+'"><div class="stat-num">'+num+'</div><div class="stat-lbl">'+lbl+'</div><div class="stat-sub">'+sub+'</div></div>';
}

/* ═══════════════════════════════════════════
   TASK CRUD
═══════════════════════════════════════════ */
function openTaskModal(defaultStatus, editId) {
  APP.editingTaskId = editId||null;
  var t = editId ? APP.tasks.find(x=>x.id===editId) : null;
  el('taskModalTitle').textContent = t ? 'EDIT TASK' : 'NEW TASK';
  el('saveTaskBtn').textContent    = t ? 'SAVE CHANGES' : 'CREATE TASK';
  el('tTitle').value    = t ? t.title   : '';
  el('tDesc').value     = t ? (t.desc||'') : '';
  el('tPriority').value = t ? t.priority : 'medium';
  el('tStatus').value   = t ? t.status   : (defaultStatus||'todo');
  el('tDue').value      = t ? (t.due||'') : '';
  el('tTags').value     = t ? (t.tags||[]).join(', ') : '';
  // populate assignee dropdown
  el('tAssignee').innerHTML = APP.users.map(u=>
    '<option value="'+u.id+'"'+(t&&t.assigneeId===u.id?' selected':(!t&&u.id===APP.currentUser.id?' selected':''))+'>'+u.name+'</option>'
  ).join('');
  el('taskModal').style.display='flex';
  setTimeout(()=>el('tTitle').focus(),80);
}

function saveTask() {
  var title = el('tTitle').value.trim();
  if (!title) { toast('Title is required','warn'); return; }
  var tags  = el('tTags').value.split(',').map(x=>x.trim()).filter(Boolean);
  var isEdit = !!APP.editingTaskId;
  if (isEdit) {
    var t = APP.tasks.find(x=>x.id===APP.editingTaskId);
    Object.assign(t, {
      title, desc:el('tDesc').value.trim(),
      priority:el('tPriority').value, status:el('tStatus').value,
      assigneeId:el('tAssignee').value, due:el('tDue').value, tags
    });
    toast('Task updated','success');
    feedLog(APP.currentUser.name.split(' ')[0]+' updated "'+title+'"');
  } else {
    var newTask = {
      id:'t'+APP.nextId++,
      title, desc:el('tDesc').value.trim(),
      priority:el('tPriority').value, status:el('tStatus').value,
      assigneeId:el('tAssignee').value, due:el('tDue').value,
      tags, created:todayStr(), comments:[]
    };
    APP.tasks.unshift(newTask);
    toast('Task created','success');
    feedLog(APP.currentUser.name.split(' ')[0]+' created "'+title+'"');
  }
  closeModal('taskModal');
  render();
}

function viewTask(id) {
  var t = APP.tasks.find(x=>x.id===id);
  if (!t) return;
  var u  = getUser(t.assigneeId);
  var od = isOverdue(t);
  el('vtModalTitle').textContent = 'TASK DETAILS';
  el('vtModalBody').innerHTML =
    '<div style="display:flex;align-items:flex-start;gap:10px;margin-bottom:14px">'+
      '<div><div style="font-family:var(--font-head);font-size:17px;font-weight:800;margin-bottom:4px">'+esc(t.title)+'</div>'+
        '<div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center">'+
          '<span class="priority-tag '+priorityClass(t.priority)+'">'+priorityLabel(t.priority)+'</span>'+
          '<span class="badge" style="background:var(--paper2);border:1px solid var(--border);font-size:10px">'+STATUSES[t.status].label+'</span>'+
          (t.tags||[]).map(tg=>'<span class="task-tag">'+tg+'</span>').join('')+
        '</div>'+
      '</div>'+
    '</div>'+
    (t.desc?'<div style="font-size:12px;color:var(--muted);margin-bottom:14px;padding:10px;background:var(--paper2)">'+esc(t.desc)+'</div>':'')+
    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;font-size:12px">'+
      '<div><div style="color:var(--muted);font-size:10px;letter-spacing:.6px;text-transform:uppercase;margin-bottom:3px">ASSIGNED TO</div>'+
        '<div style="display:flex;align-items:center;gap:6px"><div class="task-assignee" style="background:'+u.color+'">'+initials(u.name)+'</div>'+u.name+'</div></div>'+
      '<div><div style="color:var(--muted);font-size:10px;letter-spacing:.6px;text-transform:uppercase;margin-bottom:3px">DUE DATE</div>'+
        '<div style="color:'+(od?'var(--accent)':'var(--ink)')+'">'+((od?'⚠ ':'')+(t.due||'No due date'))+'</div></div>'+
      '<div><div style="color:var(--muted);font-size:10px;letter-spacing:.6px;text-transform:uppercase;margin-bottom:3px">CREATED</div><div>'+t.created+'</div></div>'+
      '<div><div style="color:var(--muted);font-size:10px;letter-spacing:.6px;text-transform:uppercase;margin-bottom:3px">COMMENTS</div><div>'+(t.comments||[]).length+' notes</div></div>'+
    '</div>'+
    '<div style="font-size:10px;letter-spacing:.6px;text-transform:uppercase;color:var(--muted);margin-bottom:7px">QUICK STATUS</div>'+
    '<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px">'+
      Object.keys(STATUSES).map(s=>'<button class="btn btn-sm'+(t.status===s?' btn-accent':' btn-outline')+'" onclick="quickStatus(\''+id+'\',\''+s+'\')">'+STATUSES[s].label+'</button>').join('')+
    '</div>'+
    '<div style="font-size:10px;letter-spacing:.6px;text-transform:uppercase;color:var(--muted);margin-bottom:7px">COMMENTS</div>'+
    '<div style="margin-bottom:8px">'+
      (t.comments||[]).map(c=>'<div style="font-size:11px;padding:6px 10px;background:var(--paper2);border-left:3px solid var(--border);margin-bottom:5px">'+esc(c)+'</div>').join('')+
    '</div>'+
    '<div style="display:flex;gap:7px"><input id="cmtInput" class="field input" placeholder="Add a comment…" style="flex:1;padding:7px 10px;font-size:11px;border:1px solid var(--border);background:var(--paper2);font-family:var(--font-mono);outline:none">'+
    '<button class="btn btn-sm btn-outline" onclick="addComment(\''+id+'\')">ADD</button></div>';

  el('vtModalFooter').innerHTML =
    '<button class="btn btn-sm btn-outline" onclick="closeModal(\'viewTaskModal\')">CLOSE</button>'+
    '<button class="btn btn-sm btn-outline" onclick="openTaskModal(null,\''+id+'\');closeModal(\'viewTaskModal\')">✎ EDIT</button>'+
    '<button class="btn btn-sm btn-danger" onclick="confirmDelete(\''+id+'\');closeModal(\'viewTaskModal\')">✕ DELETE</button>';

  el('viewTaskModal').style.display='flex';
}

function quickStatus(id, status) {
  var t = APP.tasks.find(x=>x.id===id);
  if (!t) return;
  t.status = status;
  feedLog(APP.currentUser.name.split(' ')[0]+' moved "'+t.title+'" → '+STATUSES[status].label);
  toast('Status updated','success');
  closeModal('viewTaskModal');
  render();
}

function addComment(id) {
  var inp = el('cmtInput');
  var c   = inp.value.trim();
  if (!c) return;
  var t   = APP.tasks.find(x=>x.id===id);
  if (!t) return;
  t.comments = t.comments||[];
  t.comments.push(APP.currentUser.name.split(' ')[0]+': '+c);
  inp.value = '';
  feedLog(APP.currentUser.name.split(' ')[0]+' commented on "'+t.title+'"');
  viewTask(id); // refresh modal
}

function confirmDelete(id) {
  var t = APP.tasks.find(x=>x.id===id);
  if (!t) return;
  el('confirmMsg').textContent = 'Delete "'+t.title+'"? This cannot be undone.';
  el('confirmOkBtn').onclick = ()=>{ deleteTask(id); closeModal('confirmModal'); };
  el('confirmModal').style.display='flex';
}

function deleteTask(id) {
  var t = APP.tasks.find(x=>x.id===id);
  if (t) feedLog(APP.currentUser.name.split(' ')[0]+' deleted "'+t.title+'"');
  APP.tasks = APP.tasks.filter(x=>x.id!==id);
  toast('Task deleted');
  render();
}

/* ═══════════════════════════════════════════
   DRAG & DROP
═══════════════════════════════════════════ */
var _dragId = null;
function dragStart(e, id) { _dragId=id; e.dataTransfer.effectAllowed='move'; }
function dragOver(e, col) {
  e.preventDefault(); e.dataTransfer.dropEffect='move';
  el('drop-'+col).classList.add('drag-active');
}
function dragLeave(e) {
  var dz = e.currentTarget;
  if (dz) dz.classList.remove('drag-active');
}
function dropTask(e, col) {
  e.preventDefault();
  el('drop-'+col).classList.remove('drag-active');
  if (!_dragId) return;
  var t = APP.tasks.find(x=>x.id===_dragId);
  if (t && t.status!==col) {
    t.status = col;
    feedLog(APP.currentUser.name.split(' ')[0]+' moved "'+t.title+'" → '+STATUSES[col].label);
    toast('Moved to '+STATUSES[col].label,'success');
    render();
  }
  _dragId = null;
}

/* ═══════════════════════════════════════════
   FAKE WEBSOCKET (simulated real-time)
═══════════════════════════════════════════ */
var RT_MSGS = [
  name=>'📝 '+name+' just created a new task',
  name=>'✅ '+name+' marked a task as done',
  name=>'💬 '+name+' added a comment',
  name=>'🔀 '+name+' moved a task to IN PROGRESS',
  name=>'⚠ '+name+' flagged a task as CRITICAL',
];

function startFakeWS() {
  // Simulate a WS connection with periodic fake events
  APP.wsTimer = setInterval(()=>{
    var otherUsers = APP.users.filter(u=>u.id!==APP.currentUser.id);
    if (!otherUsers.length) return;
    var rUser = otherUsers[Math.floor(Math.random()*otherUsers.length)];
    var msgFn  = RT_MSGS[Math.floor(Math.random()*RT_MSGS.length)];
    feedLog(msgFn(rUser.name.split(' ')[0]));
  }, 8000 + Math.random()*7000);
}

function feedLog(msg) {
  var now  = new Date();
  var time = now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0')+':'+now.getSeconds().toString().padStart(2,'0');
  APP.feedLog.unshift({msg, time});
  if (APP.feedLog.length>20) APP.feedLog.pop();
  renderFeed();
  updateSidebarCounts();
}

function renderFeed() {
  el('feedItems').innerHTML = APP.feedLog.slice(0,8).map(f=>
    '<div class="feed-item"><span class="feed-time">'+f.time+'</span><span>'+f.msg+'</span></div>'
  ).join('');
}

/* ═══════════════════════════════════════════
   TOAST
═══════════════════════════════════════════ */
function toast(msg, type) {
  var wrap = el('toastWrap');
  var div  = document.createElement('div');
  div.className = 'toast' + (type==='success'?' success':type==='warn'?' warn':'');
  div.textContent = msg;
  wrap.appendChild(div);
  setTimeout(()=>{ div.classList.add('out'); setTimeout(()=>div.remove(), 350); }, 2600);
}

/* ═══════════════════════════════════════════
   UTILS
═══════════════════════════════════════════ */
function el(id) { return document.getElementById(id); }
function v(id)  { return (document.getElementById(id)||{value:''}).value; }
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function closeModal(id) { var m=el(id); if(m)m.style.display='none'; }
</script>
